datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Employee {
  id           Int      @id @default(autoincrement())
  name         String
  employeeId   String   @unique
  department   String?
  attendances  Attendance[]
}

model Attendance {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  date        DateTime
  status      String

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date]) // 🚨 prevents duplicate entry per day
}

model Guest {
  id    Int      @id @default(autoincrement())
  name  String
  date  DateTime
}