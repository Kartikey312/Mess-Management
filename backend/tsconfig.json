{
"compilerOptions": {
"target": "ES2020",
"module": "CommonJS",
"moduleResolution": "node",
"ignoreDeprecations": "6.0",


"rootDir": "./src",
"outDir": "./dist",
"esModuleInterop": true,
"strict": true,

"types": ["node"],
"skipLibCheck": true,
"resolveJsonModule": true,

"forceConsistentCasingInFileNames": true,
"noImplicitReturns": true,
"noUnusedLocals": true,
"noUnusedParameters": true


},
"include": ["src"],
"exclude": ["node_modules", "dist"]
}
